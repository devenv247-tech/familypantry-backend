generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Family {
  id                   String             @id @default(cuid())
  name                 String
  plan                 String             @default("free")
  recipeCount          Int                @default(0)
  recipeWeek           String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  photoScanCount       Int                @default(0)
  photoScanMonth       String?
  users                User[]
  members              Member[]
  pantryItems          PantryItem[]
  groceryItems         GroceryItem[]
  mealPlans            MealPlan[]
  usageHistory         ItemUsageHistory[]
  cookedMeals          CookedMeal[]
  nutritionLogs        NutritionLog[]
  priceHistory         PriceHistory[]
  savedRecipes         SavedRecipe[]
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String
  role             String    @default("member")
  isAdmin          Boolean   @default(false)
  familyId         String
  family           Family    @relation(fields: [familyId], references: [id])
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
}

model Member {
  id               String         @id @default(cuid())
  name             String
  role             String         @default("Member")
  age              Int?
  weight            Float?
  weightUnit        String?   @default("kg")
  height            String?
  goals            String?
  dietary          String?
  allergens        String?
  dailyCalorieGoal Int?
  goalWeight       Float?
  familyId         String
  family           Family         @relation(fields: [familyId], references: [id])
  nutritionLogs    NutritionLog[]
  weightLogs       WeightLog[]
  createdAt        DateTime       @default(now())
}

model PantryItem {
  id               String    @id @default(cuid())
  name             String
  quantity         Float     @default(0)
  unit             String    @default("pcs")
  category         String
  expiry           String?
  predictedExpiry  DateTime?
  expiryConfidence String?
  expirySource     String?   @default("manual")
  icon             String?
  familyId         String
  family           Family    @relation(fields: [familyId], references: [id])
  createdAt        DateTime  @default(now())
}

model GroceryItem {
  id          String    @id @default(cuid())
  name        String
  qty         String?
  store       String?
  price       String?
  category    String?
  checked     Boolean   @default(false)
  purchased   Boolean   @default(false)
  purchasedAt DateTime?
  familyId    String
  family      Family    @relation(fields: [familyId], references: [id])
  createdAt   DateTime  @default(now())
}

model MealPlan {
  id         String   @id @default(cuid())
  weekStart  String
  day        String
  mealType   String
  recipeName String
  recipeData Json
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id])
  createdAt  DateTime @default(now())
}

model ItemUsageHistory {
  id              String    @id @default(cuid())
  itemName        String
  category        String?
  addedAt         DateTime  @default(now())
  removedAt       DateTime?
  predictedExpiry DateTime?
  actualExpiry    DateTime?
  removalReason   String?
  familyId        String
  family          Family    @relation(fields: [familyId], references: [id])
}

model CookedMeal {
  id         String   @id @default(cuid())
  recipeName String
  mealType   String
  cuisine    String?
  members    String
  cookedAt   DateTime @default(now())
  rating     Int?
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id])
}

model NutritionLog {
  id         String   @id @default(cuid())
  memberName String
  memberId   String?
  member     Member?  @relation(fields: [memberId], references: [id])
  recipeName String
  mealType   String
  calories   Float?
  protein    Float?
  carbs      Float?
  fat        Float?
  fiber      Float?
  sugar      Float?
  sodium     Float?
  loggedAt   DateTime @default(now())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id])
}

model PriceHistory {
  id         String   @id @default(cuid())
  itemName   String
  price      Float
  store      String?
  recordedAt DateTime @default(now())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id])
}

model SavedRecipe {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  icon                String?
  time                String?
  difficulty          String?
  serves              Int?
  tags                Json?
  ingredients         Json?
  missing             Json?
  steps               Json?
  nutrition           Json?
  nutritionPerServing Json?
  allergenWarnings    Json?
  familyId            String
  family              Family   @relation(fields: [familyId], references: [id])
  createdAt           DateTime @default(now())
}

model FeatureFlag {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  enabled      Boolean  @default(true)
  requiredPlan String   @default("free")
  comingSoon   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  icon      String   @default("🎉")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model WeightLog {
  id       String   @id @default(cuid())
  memberId String
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  weight   Float
  unit     String   @default("kg")
  note     String?
  loggedAt DateTime @default(now())
}

model NutritionCache {
  id          String   @id @default(cuid())
  searchKey   String   @unique
  mealName    String
  calories    Float?
  protein     Float?
  carbs       Float?
  fat         Float?
  fiber       Float?
  sugar       Float?
  sodium      Float?
  servingSize String?
  source      String?
  confidence  String?
  hitCount    Int      @default(1)
  createdAt   DateTime @default(now())
  expiresAt   DateTime
}